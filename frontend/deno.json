{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi npm:vite dev",
    "build": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi npm:vite build",
    "preview": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi npm:vite preview",
    "sync": "deno run --allow-read --allow-write --allow-env --allow-run --allow-sys --allow-ffi npm:@sveltejs/kit sync",
    "check": "deno task sync && deno run --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys --allow-ffi npm:svelte-check --tsconfig ./tsconfig.json",
    "fmt": "deno fmt && deno run --allow-read --allow-write --allow-env --allow-sys npm:prettier --plugin prettier-plugin-svelte --write 'src/**/*.svelte'",
    "fmt:svelte": "deno run --allow-read --allow-write --allow-env --allow-sys npm:prettier --plugin prettier-plugin-svelte --write 'src/**/*.svelte'",
    "lint": "deno lint",
    "storybook": "deno run -A npm:storybook dev -p 6006",
    "build-storybook": "deno run -A npm:storybook build",
    "test-storybook": "deno run -A npm:vitest --project=storybook"
  },
  "fmt": {
    "exclude": [".svelte-kit/", "node_modules/", "build/", "storybook-static/"]
  },
  "lint": {
    "exclude": [".svelte-kit/", "node_modules/", "build/", "storybook-static/"],
    "rules": {
      "exclude": ["no-sloppy-imports"]
    }
  }
}
