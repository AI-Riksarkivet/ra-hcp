{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite dev",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "sync": "deno run -A npm:@sveltejs/kit sync",
    "check": "deno task sync && deno run -A npm:svelte-check --tsconfig ./tsconfig.json",
    "fmt": "deno fmt && deno run -A npm:prettier --plugin prettier-plugin-svelte --write 'src/**/*.svelte'",
    "fmt:svelte": "deno run -A npm:prettier --plugin prettier-plugin-svelte --write 'src/**/*.svelte'",
    "lint": "deno lint"
  },
  "fmt": {
    "exclude": [".svelte-kit/", "node_modules/", "build/"]
  },
  "lint": {
    "exclude": [".svelte-kit/", "node_modules/", "build/"]
  }
}
