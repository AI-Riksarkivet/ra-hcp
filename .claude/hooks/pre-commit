#!/usr/bin/env bash
# Pre-commit: format and lint staged files via Makefile
set -euo pipefail

export PATH="$HOME/.deno/bin:$PATH"

# Format all code (same as make fmt)
make -C "$(git rev-parse --show-toplevel)" fmt 2>&1 | tail -3

# Lint all code (same as make lint)
if ! make -C "$(git rev-parse --show-toplevel)" lint 2>&1; then
  echo ""
  echo "Commit blocked: lint errors found. Run 'make quality' to investigate."
  exit 1
fi

# Re-stage any files that were reformatted
CHANGED=$(git diff --name-only -- '*.py' '*.ts' '*.js' '*.svelte')
if [ -n "$CHANGED" ]; then
  echo "$CHANGED" | xargs git add
  echo "Auto-formatted and re-staged: $(echo "$CHANGED" | wc -l) file(s)"
fi
