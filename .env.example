# =======================================================================
# HCP Control Plane — Environment Configuration
# =======================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── How HCP URL routing works ────────────────────────────────────────
#
# HCP uses virtual-hosted style URLs. All URLs are built from a single
# base domain. The subdomain determines the access scope.
#
#   Example domain: hcp.ra-dev.int
#                   └── HCP system domain on the ra-dev internal network
#
#   An HCP system can host multiple tenants. Each tenant gets its own
#   subdomain. The system admin uses the special "admin." subdomain.
#
#   Network topology:
#   ┌─────────────────────────────────────────────────────────────────┐
#   │  hcp.ra-dev.int                    ← HCP system domain         │
#   │  ├── admin.hcp.ra-dev.int:9090     ← system MAPI (infra team) │
#   │  ├── dev-ai.hcp.ra-dev.int:9090    ← tenant MAPI              │
#   │  ├── dev-ai.hcp.ra-dev.int:8000    ← tenant GUI console       │
#   │  ├── dev-ai.hcp.ra-dev.int         ← S3 data plane            │
#   │  └── other-team.hcp.ra-dev.int     ← another tenant           │
#   └─────────────────────────────────────────────────────────────────┘
#
#   MAPI (Management API, port 9090):
#   ┌─────────────────────────────────────────────────────────────────┐
#   │ Scope          Host                    Path examples            │
#   │ ─────────────  ──────────────────────  ─────────────────────── │
#   │ System admin   admin.{domain}:9090     /mapi/tenants           │
#   │                                        /mapi/userAccounts      │
#   │                                                                │
#   │ Tenant admin   {tenant}.{domain}:9090  /mapi/tenants/{tenant}/ │
#   │                                          namespaces            │
#   │                                        /mapi/tenants/{tenant}/ │
#   │                                          userAccounts          │
#   │                                                                │
#   │ System admin   admin.{domain}:9090     /mapi/tenants/{tenant}/ │
#   │ managing a                               userAccounts          │
#   │ tenant         (system admins can also manage tenant resources  │
#   │                 via the admin. host)                            │
#   └─────────────────────────────────────────────────────────────────┘
#
#   S3 (Data Plane):
#   ┌─────────────────────────────────────────────────────────────────┐
#   │ Target         URL                                             │
#   │ ─────────────  ─────────────────────────────────────────────── │
#   │ List buckets   {tenant}.{domain}                               │
#   │ Bucket         {bucket}.{tenant}.{domain}                      │
#   │   (path alt)   {tenant}.{domain}/{bucket}                      │
#   │ Object         {bucket}.{tenant}.{domain}/{key}                │
#   └─────────────────────────────────────────────────────────────────┘
#
# ── Access levels ────────────────────────────────────────────────────
#
# System-level users (admin. host):
#   - Manage tenants, system user accounts, infrastructure,
#     replication, erasure coding, licenses, health checks
#   - Require system-level roles (administrator, monitor, security)
#
# Tenant-level users ({tenant}. host):
#   - Manage namespaces, tenant user accounts, content classes
#     within their tenant only
#   - Cannot list or manage other tenants
#   - Require tenant-level roles (administrator, monitor, security,
#     compliance)
#
# Namespace users (S3 only):
#   - Access objects in buckets they have ACL permissions for
#   - No MAPI access needed
#
# A tenant-level user hitting admin.{domain} will get 403 Forbidden.
# A system-level user can manage any tenant via admin.{domain}.
#
# ── Authentication ───────────────────────────────────────────────────
#
# Credentials are provided per-user at login (not in this file).
# The login flow:
#   1. User sends username + password (+ tenant) to our API
#   2. Our API returns a JWT containing the credentials
#   3. On each request, credentials are forwarded to HCP
#   4. HCP validates them and enforces permissions based on the
#      user's roles
#
# HCP auth token format:
#   HCP auth:  Authorization: HCP base64(username):md5(password)
#   AD auth:   Authorization: AD username@domain:password
#
# S3 credentials are derived the same way:
#   access_key = base64(username)
#   secret_key = md5(password)
#
# =======================================================================

# ── HCP Management API (MAPI) ────────────────────────────────────────
# HCP_HOST — the MAPI hostname your backend connects to.
#   System-level access:  admin.<your-hcp-domain>
#   Tenant-level access:  <tenant>.<your-hcp-domain>
#
# Use the tenant host if your service account is a tenant-level user.
# Use the admin host only if you have a system-level account.
HCP_HOST=admin.hcp.example.com
HCP_DOMAIN=                       # e.g. hcp.ra-dev.int — base for tenant host derivation
HCP_PORT=9090
HCP_USERNAME=              # fallback service account (optional)
HCP_PASSWORD=              # fallback service account (optional)
HCP_AUTH_TYPE=hcp          # hcp | ad
HCP_VERIFY_SSL=false
HCP_TIMEOUT=60

# ── HCP S3 Data Plane ───────────────────────────────────────────────
# S3 endpoint — always the tenant host: <tenant>.<your-hcp-domain>
S3_ENDPOINT_URL=https://europe.hcp.example.com
S3_REGION=us-east-1

# ── API Authentication ──────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production   # used to sign JWTs
API_TOKEN_EXPIRE_MINUTES=480             # 8 hours
CORS_ORIGINS=                            # comma-separated, empty = allow all

# ── Redis Cache (optional) ──────────────────────────────────────────
REDIS_URL=                  # empty = no caching (e.g. redis://localhost:6379)
CACHE_DEFAULT_TTL=300       # 5 min  — MAPI listings
CACHE_STATS_TTL=60          # 1 min  — statistics
CACHE_CONFIG_TTL=600        # 10 min — security/permissions
CACHE_S3_LIST_TTL=120       # 2 min  — bucket/object listings
CACHE_S3_META_TTL=300       # 5 min  — head/ACL metadata
CACHE_KEY_PREFIX=hcp
