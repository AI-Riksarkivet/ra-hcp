[default]
region = us-east-1
# Disable automatic checksums — AWS CLI v2 sends CRC64NVME checksums as
# HTTP trailers via chunked transfer encoding, which strips Content-Length.
# HCP requires Content-Length and does not support aws-chunked encoding.
request_checksum_calculation = when_required
s3 =
    addressing_style = path
    payload_signing_enabled = true
